# 눈치맵 앱 환경변수
# 이 파일을 .env 로 복사한 뒤 값 채워넣기.
# EXPO_PUBLIC_ 프리픽스만 클라이언트 번들에 포함됨.

# 백엔드 (Next.js) BASE URL.
# - 같은 PC 에뮬레이터:  http://localhost:3000
# - 실기기 + Expo Go:     http://<내PC LAN IP>:3000  (예: http://192.168.0.10:3000)
# - 운영 배포:            https://nunchimap.vercel.app
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# 카카오 디벨로퍼스 → 내 애플리케이션 → 앱 키 → REST API 키
# (웹의 KAKAO_OAUTH_CLIENT_ID 와 동일한 값)
EXPO_PUBLIC_KAKAO_REST_API_KEY=

# 카카오 디벨로퍼스 → 내 애플리케이션 → 앱 키 → JavaScript 키
# 카카오맵 SDK(WebView)에 필요. REST API 키와 다른 값임.
# 플랫폼 등록: 카카오 디벨로퍼스 → 플랫폼 → Web → 사이트 도메인에
#   http://localhost  추가 (WebView용)
EXPO_PUBLIC_KAKAO_JS_KEY=
